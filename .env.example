# Environment variable template. Copy to .env and fill values.
# Used by Flask (backend), Docker Compose. Never commit .env.
#
# For production: backend runs on Render (env set in Render Dashboard);
# frontend runs on Vercel — set VITE_API_URL in Vercel (see docs/DEPLOYMENT.md).

# Share in Discord for security
# (as in, don't type out the values in Discord, share them over a secure channel, just share how you got your .env values)

# --- Database (local: docker-compose MySQL; production: Railway MySQL; set in Render) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=syllabify
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# --- Flask ---
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-secret-key-here

# --- JWT (app uses SECRET_KEY for JWT; these are optional overrides) ---
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_DELTA=86400

# --- Google OAuth (Sign-in + Calendar import) ---
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Redirect URI for Calendar OAuth (must match Google Cloud Console). Backend handles callback.
GOOGLE_REDIRECT_URI=http://localhost:5000/api/calendar/callback

# --- CORS: backend allows this origin (local dev vs production) ---
# Local: Vite dev server runs on 5173 by default. Production: set on Render to your Vercel URL.
FRONTEND_URL=http://localhost:5173

# --- Hybrid syllabus parser (LLM + heuristics; set on Render for deployed backend) ---
# Enable hybrid parser: when true, uses OpenAI to parse syllabi; falls back to rule-based if LLM fails.
USE_LLM_PARSER=false
# Required when USE_LLM_PARSER=true. Get from platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Frontend only (create frontend/.env.local) ---
# With docker-compose, backend is on port 5001. Without Docker, use 5000.
# VITE_API_URL=http://localhost:5001
# VITE_GOOGLE_CLIENT_ID=your-google-client-id  # Same as GOOGLE_CLIENT_ID; for Sign in with Google button
# Production: set in Vercel Environment Variables.
